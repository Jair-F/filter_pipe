{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Tests",
            "type": "shell",
            "command": "python3 -m pytest",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
        },
        {
            "label": "Run App",
            "type": "shell",
            "command": "python3 -m src.app",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
        },
        {
            "label": "pre-commit",
            "type": "shell",
            "command": "pre-commit run --all-files",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": true
            },
        },
    ]
}
